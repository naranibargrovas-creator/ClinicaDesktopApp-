<Window x:Class="CLINICA_CITAS.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:helpers="clr-namespace:CLINICA_CITAS.Helpers"
        mc:Ignorable="d"
        Title="Inicio de Sesión"
        Height="560" 
        Width="460"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize">

    <Grid>
        <!-- Outer Shadow / Margin Area for Window Drag & Rounded corners -->
        <Border Background="#F3F4F6"
                CornerRadius="16"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                Margin="10">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" 
                                  Direction="-90" 
                                  ShadowDepth="3" 
                                  Opacity="0.15" 
                                  Color="#000000"/>
            </Border.Effect>
            
            <Grid>
                <Grid.RowDefinitions>
                    <!-- Custom Drag Titlebar -->
                    <RowDefinition Height="40"/>
                    <!-- Main Login Area -->
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Drag Handle & Controls -->
                <Border Grid.Row="0" 
                        Background="Transparent" 
                        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid>
                        <!-- App Icon / Small Title -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                            <TextBlock Text="⚕️" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Clínica Citas" 
                                       FontFamily="Segoe UI" 
                                       FontWeight="SemiBold" 
                                       Foreground="#4B5563" 
                                       FontSize="12" 
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Window Controls -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,12,0">
                            <Button Content="—" 
                                    Width="30" 
                                    Height="24" 
                                    Background="Transparent" 
                                    BorderThickness="0" 
                                    Foreground="#6B7280" 
                                    FontWeight="Bold"
                                    Cursor="Hand"
                                    Click="BtnMinimize_Click">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="4">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="border" Property="Background" Value="#E5E7EB"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                            
                            <Button Content="✕" 
                                    Width="30" 
                                    Height="24" 
                                    Background="Transparent" 
                                    BorderThickness="0" 
                                    Foreground="#6B7280" 
                                    FontWeight="Bold"
                                    Cursor="Hand"
                                    Click="BtnClose_Click"
                                    Margin="4,0,0,0">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="4">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="border" Property="Background" Value="#EF4444"/>
                                                            <Setter Property="Foreground" Value="White"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Login Main Card -->
                <Grid Grid.Row="1" Margin="24,8,24,32">
                    <Border Background="#FFFFFF"
                            CornerRadius="12"
                            BorderBrush="#E5E7EB"
                            BorderThickness="1">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10" 
                                              Direction="-90" 
                                              ShadowDepth="2" 
                                              Opacity="0.06" 
                                              Color="#000000"/>
                        </Border.Effect>

                        <StackPanel Margin="32,24,32,24" VerticalAlignment="Center">
                            <!-- Title -->
                            <TextBlock Text="Inicio de Sesión" 
                                       Style="{StaticResource HeaderTextStyle}"/>

                            <!-- Email Field -->
                            <TextBlock Text="Correo" 
                                       Style="{StaticResource LabelTextStyle}"/>
                            <TextBox x:Name="TxtCorreo"
                                     Tag="Ingresa tu correo"
                                     Style="{StaticResource ModernTextBox}"
                                     Margin="0,0,0,20"/>

                            <!-- Password Field -->
                            <TextBlock Text="Contraseña" 
                                       Style="{StaticResource LabelTextStyle}"/>
                            <PasswordBox x:Name="TxtContrasena"
                                         helpers:PasswordBoxHelper.Watermark="Ingresa tu contraseña"
                                         Style="{StaticResource ModernPasswordBox}"
                                         Margin="0,0,0,28"/>

                            <!-- Submit Button -->
                            <Button Content="Iniciar Sesión" 
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Click="BtnLogin_Click"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
