<Window x:Class="CLINICA_CITAS.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CLINICA_CITAS"
        mc:Ignorable="d"
        Title="Dashboard - Clínica Citas" 
        Height="700" 
        Width="1200"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize">

    <Grid>
        <!-- Outer Shadow / Margin Area -->
        <Border Background="#F3F4F6"
                CornerRadius="16"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                Margin="10">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" 
                                  Direction="-90" 
                                  ShadowDepth="3" 
                                  Opacity="0.15" 
                                  Color="#000000"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <!-- Drag Titlebar -->
                    <RowDefinition Height="40"/>
                    <!-- Dashboard Content -->
                    <RowDefinition Height="101*"/>
                    <RowDefinition Height="268*"/>
                </Grid.RowDefinitions>

                <!-- Titlebar -->
                <Border Grid.Row="0" 
                        Background="Transparent" 
                        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid>
                        <!-- App Icon / Title -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                            <TextBlock Text="⚕️" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Clínica Citas - Panel de Control" 
                                       FontFamily="Segoe UI" 
                                       FontWeight="SemiBold" 
                                       Foreground="#4B5563" 
                                       FontSize="12" 
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Window Controls -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,12,0">
                            <Button Content="—" 
                                    Width="30" 
                                    Height="24" 
                                    Background="Transparent" 
                                    BorderThickness="0" 
                                    Foreground="#6B7280" 
                                    FontWeight="Bold"
                                    Cursor="Hand"
                                    Click="BtnMinimize_Click">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="4">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="border" Property="Background" Value="#E5E7EB"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <Button Content="✕" 
                                    Width="30" 
                                    Height="24" 
                                    Background="Transparent" 
                                    BorderThickness="0" 
                                    Foreground="#6B7280" 
                                    FontWeight="Bold"
                                    Cursor="Hand"
                                    Click="BtnClose_Click"
                                    Margin="4,0,0,0">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="4">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="border" Property="Background" Value="#EF4444"/>
                                                            <Setter Property="Foreground" Value="White"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Dashboard Body -->
                <Grid Grid.Row="1" Margin="24,8,24,24" Grid.RowSpan="2">
                    <Grid.ColumnDefinitions>
                        <!-- Sidebar -->
                        <ColumnDefinition Width="48"/>
                        <ColumnDefinition Width="97.857"/>
                        <ColumnDefinition Width="102.143"/>
                        <!-- Main Panel -->
                        <ColumnDefinition Width="84*"/>
                        <ColumnDefinition Width="35*"/>
                        <ColumnDefinition Width="77*"/>
                        <ColumnDefinition Width="510*"/>
                        <ColumnDefinition Width="184*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Sidebar Card -->
                    <Border Grid.Column="0" 
                            Background="#FFFFFF" 
                            CornerRadius="12" 
                            BorderBrush="#E5E7EB" 
                            BorderThickness="1"
                            Margin="0,0,16,0" Grid.ColumnSpan="3">
                        <Grid Margin="16">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Profile Greeting -->
                            <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,16,0,0">
                                <!--<Border Width="60" Height="60" CornerRadius="30" Background="#0B72E7" HorizontalAlignment="Center" Margin="0,0,0,12">
                                    <TextBlock x:Name="TxtInitial" Text="C" Foreground="White" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,14"/>
                                </Border>-->
                                <!--<TextBlock x:Name="TxtUserName" Text="Carlos Ramírez" FontSize="16" FontWeight="SemiBold" Foreground="#1E293B" TextAlignment="Center" TextWrapping="Wrap"/>-->
                                <Border Background="#E0F2FE" CornerRadius="12" Padding="8,4,8,4" Margin="0,6,0,0" HorizontalAlignment="Center">
                                    <TextBlock x:Name="TxtUserRol" Text="Administrador" FontSize="11" FontWeight="Medium" Foreground="#0369A1"/>
                                </Border>
                            </StackPanel>
                            <!-- Navigation List -->
                            <StackPanel Grid.Row="1" Margin="0,24,0,0" VerticalAlignment="Top">
                                <TextBlock Text="Menú del Sistema" FontSize="11" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,8"/>
                                
                                <Border x:Name="BorderMenuInicio" Background="#F1F5F9" CornerRadius="6" Padding="8" Margin="0,0,0,4" Cursor="Hand" MouseLeftButtonDown="MenuInicio_Click">
                                    <TextBlock x:Name="TxtMenuInicio" Text="🏠 Inicio" FontSize="13" FontWeight="SemiBold" Foreground="#0B72E7"/>
                                </Border>
                                
                                <Border x:Name="BorderMenuPacientes" Background="Transparent" CornerRadius="6" Padding="8" Margin="0,0,0,4" Cursor="Hand" MouseLeftButtonDown="MenuPacientes_Click">
                                    <TextBlock x:Name="TxtMenuPacientes" Text="👤 Gestión de Pacientes" FontSize="13" FontWeight="Medium" Foreground="#475569"/>
                                </Border>

                                <Border x:Name="BorderMenuMedicos" Background="Transparent" CornerRadius="6" Padding="8" Margin="0,0,0,4" Cursor="Hand" MouseLeftButtonDown="MenuMedicos_Click">
                                    <TextBlock x:Name="TxtMenuMedicos" Text="⚕️ Gestión de Médicos" FontSize="13" FontWeight="Medium" Foreground="#475569"/>
                                </Border>

                                <Border x:Name="BorderMenuCitas" Background="Transparent" CornerRadius="6" Padding="8" Margin="0,0,0,4" Cursor="Hand" MouseLeftButtonDown="MenuCitas_Click">
                                    <TextBlock x:Name="TxtMenuCitas" Text="📅 Gestión de Citas" FontSize="13" FontWeight="Medium" Foreground="#475569"/>
                                </Border>

                                <Border x:Name="BorderMenuUsuarios" Background="Transparent" CornerRadius="6" Padding="8" Margin="0,0,0,4" Cursor="Hand" MouseLeftButtonDown="MenuUsuarios_Click">
                                    <TextBlock x:Name="TxtMenuUsuarios" Text="👥 Administrar Usuarios" FontSize="13" FontWeight="Medium" Foreground="#475569"/>
                                </Border>
                                
                                <TextBlock Text="🔒 Próximos Módulos" FontSize="11" FontWeight="Bold" Foreground="#94A3B8" Margin="0,16,0,8"/>
                                <TextBlock Text="🛡️ Proveedores de Seguros" FontSize="12" Foreground="#94A3B8" Margin="8,4,0,4"/>
                                <TextBlock Text="📋 Historial Clínico" FontSize="12" Foreground="#94A3B8" Margin="8,4,0,4"/>
                                <TextBlock Text="📦 Almacén e Insumos" FontSize="12" Foreground="#94A3B8" Margin="8,4,0,4"/>
                            </StackPanel>

                            <!-- Logout Button -->
                            <Button Grid.Row="2" 
                                    Content="Cerrar Sesión" 
                                    Background="Transparent" 
                                    BorderThickness="0" 
                                    Foreground="#EF4444" 
                                    FontWeight="SemiBold"
                                    Cursor="Hand"
                                    Click="BtnLogout_Click"
                                    Margin="0,0,0,8"/>
                        </Grid>
                    </Border>

                    <!-- CONTENEDOR PRINCIPAL DE PANELES -->
                    <Grid Grid.Column="2" Grid.ColumnSpan="6" Margin="94,0,8,0">
                        
                        <!-- PANEL 1: DASHBOARD -->
                        <Grid x:Name="PanelDashboard" Visibility="Visible">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Welcome card -->
                            <Border Grid.Row="0" Background="#FFFFFF" CornerRadius="12" BorderBrush="#E5E7EB" BorderThickness="1" Padding="24" Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="🎉 ¡Inicio de Sesión Exitoso!" FontSize="22" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,8"/>
                                    <TextBlock x:Name="TxtWelcomeMsg" Text="Hola Usuario, bienvenido de vuelta al sistema de gestión de citas." FontSize="14" Foreground="#64748B"/>
                                </StackPanel>
                            </Border>

                            <!-- Stats Grid -->
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Card 1: Pacientes -->
                                <Border Grid.Row="0" Grid.Column="0" Background="#FFFFFF" CornerRadius="12" BorderBrush="#E5E7EB" BorderThickness="1" Margin="0,0,8,8" Padding="16">
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock Text="👤" FontSize="32" Foreground="#0B72E7" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                        <TextBlock Text="Total Pacientes Activos" FontSize="14" Foreground="#64748B" FontWeight="Medium" HorizontalAlignment="Center"/>
                                        <TextBlock x:Name="TxtStatPacientes" Text="0" FontSize="36" FontWeight="Bold" Foreground="#1E293B" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- Card 2: Médicos -->
                                <Border Grid.Row="0" Grid.Column="1" Background="#FFFFFF" CornerRadius="12" BorderBrush="#E5E7EB" BorderThickness="1" Margin="8,0,0,8" Padding="16">
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock Text="⚕️" FontSize="32" Foreground="#10B981" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                        <TextBlock Text="Total Médicos" FontSize="14" Foreground="#64748B" FontWeight="Medium" HorizontalAlignment="Center"/>
                                        <TextBlock x:Name="TxtStatMedicos" Text="0" FontSize="36" FontWeight="Bold" Foreground="#1E293B" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- Card 3: Citas Hoy -->
                                <Border Grid.Row="1" Grid.Column="0" Background="#FFFFFF" CornerRadius="12" BorderBrush="#E5E7EB" BorderThickness="1" Margin="0,8,8,0" Padding="16">
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock Text="⏰" FontSize="32" Foreground="#F59E0B" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                        <TextBlock Text="Citas de Hoy" FontSize="14" Foreground="#64748B" FontWeight="Medium" HorizontalAlignment="Center"/>
                                        <TextBlock x:Name="TxtStatCitasHoy" Text="0" FontSize="36" FontWeight="Bold" Foreground="#1E293B" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- Card 4: Citas Pendientes -->
                                <Border Grid.Row="1" Grid.Column="1" Background="#FFFFFF" CornerRadius="12" BorderBrush="#E5E7EB" BorderThickness="1" Margin="8,8,0,0" Padding="16">
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock Text="📅" FontSize="32" Foreground="#8B5CF6" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                        <TextBlock Text="Citas Pendientes / Confirmadas" FontSize="14" Foreground="#64748B" FontWeight="Medium" HorizontalAlignment="Center"/>
                                        <TextBlock x:Name="TxtStatCitasPendientes" Text="0" FontSize="36" FontWeight="Bold" Foreground="#1E293B" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>

                        <!-- PANEL 2: PACIENTES -->
                        <Grid x:Name="PanelPacientes" Visibility="Collapsed">
                            <!-- List View -->
                            <Grid x:Name="GridPacienteList" Visibility="Visible">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Search and Actions -->
                                <Grid Grid.Row="0" Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="Gestión de Pacientes" FontSize="22" FontWeight="Bold" Foreground="#1E293B" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1" x:Name="TxtBuscarPaciente" Tag="Buscar por nombre, apellidos o doc..." Style="{StaticResource ModernTextBox}" Height="40" Margin="16,0,8,0" VerticalAlignment="Center"/>
                                    <Button Grid.Column="2" Content="🔍 Buscar" Style="{StaticResource SecondaryButtonStyle}" Width="90" Height="40" Margin="0,0,8,0" Click="BtnBuscarPaciente_Click" VerticalAlignment="Center"/>
                                    <Button Grid.Column="3" Content="➕ Registrar Paciente" Style="{StaticResource PrimaryButtonStyle}" Height="40" Padding="16,0,16,0" Click="BtnNuevoPaciente_Click" VerticalAlignment="Center"/>
                                </Grid>

                                <!-- Table -->
                                <Border Grid.Row="1" Background="#FFFFFF" CornerRadius="12" BorderBrush="#E5E7EB" BorderThickness="1" Padding="12">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <DataGrid Grid.Row="0" x:Name="DgPacientes" Style="{StaticResource ModernDataGrid}">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Nº Documento" Binding="{Binding NumeroDoc}" Width="110"/>
                                                <DataGridTextColumn Header="Nombres" Binding="{Binding Nombre}" Width="130"/>
                                                <DataGridTextColumn Header="Apellidos" Binding="{Binding Apellidos}" Width="160"/>
                                                <DataGridTextColumn Header="Teléfono" Binding="{Binding Telefono}" Width="100"/>
                                                <DataGridTextColumn Header="Correo" Binding="{Binding Correo}" Width="160"/>
                                                <DataGridTextColumn Header="Sexo" Binding="{Binding Sexo}" Width="60"/>
                                                <DataGridTextColumn Header="Estado" Binding="{Binding EstadoTexto}" Width="80"/>
                                            </DataGrid.Columns>
                                        </DataGrid>

                                        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                                            <Button Content="✏️ Editar Paciente" Style="{StaticResource SecondaryButtonStyle}" Width="140" Height="36" Margin="0,0,8,0" Click="BtnEditarPaciente_Click"/>
                                            <Button Content="🏥 Dar de Alta" Style="{StaticResource SecondaryButtonStyle}" Foreground="#10B981" BorderBrush="#A7F3D0" Width="120" Height="36" Click="BtnDarAltaPaciente_Click"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>

                            <!-- Form View -->
                            <Grid x:Name="GridPacienteForm" Visibility="Collapsed">
                                <Border Background="#FFFFFF" CornerRadius="12" BorderBrush="#E5E7EB" BorderThickness="1" Padding="24">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" x:Name="LblTituloFormPaciente" Text="Registrar Paciente" FontSize="20" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,16"/>

                                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,16">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,12">
                                                    <TextBlock Text="Nombres *" Style="{StaticResource LabelTextStyle}"/>
                                                    <TextBox x:Name="TxtPacNombre" Tag="Ej. Juan" Style="{StaticResource ModernTextBox}" Height="40"/>
                                                </StackPanel>
                                                <StackPanel Grid.Row="0" Grid.Column="1" Margin="8,0,0,12">
                                                    <TextBlock Text="Apellidos *" Style="{StaticResource LabelTextStyle}"/>
                                                    <TextBox x:Name="TxtPacApellidos" Tag="Ej. Pérez" Style="{StaticResource ModernTextBox}" Height="40"/>
                                                </StackPanel>

                                                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,12">
                                                    <TextBlock Text="Tipo Documento *" Style="{StaticResource LabelTextStyle}"/>
                                                    <ComboBox x:Name="CbPacTipoDoc" Height="40" VerticalContentAlignment="Center">
                                                        <ComboBoxItem Content="DNI" IsSelected="True"/>
                                                        <ComboBoxItem Content="Pasaporte"/>
                                                        <ComboBoxItem Content="Carnet Extranjería"/>
                                                    </ComboBox>
                                                </StackPanel>
                                                <StackPanel Grid.Row="1" Grid.Column="1" Margin="8,0,0,12">
                                                    <TextBlock Text="Número Documento *" Style="{StaticResource LabelTextStyle}"/>
                                                    <TextBox x:Name="TxtPacNumeroDoc" Tag="Ej. 12345678" Style="{StaticResource ModernTextBox}" Height="40"/>
                                                </StackPanel>

                                                <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,8,12">
                                                    <TextBlock Text="Sexo *" Style="{StaticResource LabelTextStyle}"/>
                                                    <ComboBox x:Name="CbPacSexo" Height="40" VerticalContentAlignment="Center">
                                                        <ComboBoxItem Content="Masculino" Tag="M" IsSelected="True"/>
                                                        <ComboBoxItem Content="Femenino" Tag="F"/>
                                                    </ComboBox>
                                                </StackPanel>
                                                <StackPanel Grid.Row="2" Grid.Column="1" Margin="8,0,0,12">
                                                    <TextBlock Text="Fecha de Nacimiento" Style="{StaticResource LabelTextStyle}"/>
                                                    <DatePicker x:Name="DpPacFechaNacimiento" Height="40" VerticalContentAlignment="Center"/>
                                                </StackPanel>

                                                <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,8,12">
                                                    <TextBlock Text="Teléfono *" Style="{StaticResource LabelTextStyle}"/>
                                                    <TextBox x:Name="TxtPacTelefono" Tag="Ej. 987654321" Style="{StaticResource ModernTextBox}" Height="40"/>
                                                </StackPanel>
                                                <StackPanel Grid.Row="3" Grid.Column="1" Margin="8,0,0,12">
                                                    <TextBlock Text="Correo Electrónico" Style="{StaticResource LabelTextStyle}"/>
                                                    <TextBox x:Name="TxtPacCorreo" Tag="Ej. juan.perez@email.com" Style="{StaticResource ModernTextBox}" Height="40"/>
                                                </StackPanel>

                                                <StackPanel Grid.Row="4" Grid.Column="0" Margin="0,0,8,12">
                                                    <TextBlock Text="Dirección *" Style="{StaticResource LabelTextStyle}"/>
                                                    <TextBox x:Name="TxtPacDireccion" Tag="Ej. Av. Larco 123" Style="{StaticResource ModernTextBox}" Height="40"/>
                                                </StackPanel>
                                                <StackPanel Grid.Row="4" Grid.Column="1" Margin="8,16,0,12" VerticalAlignment="Center">
                                                    <CheckBox x:Name="ChkPacEstado" Content="Paciente Activo (En atención)" IsChecked="True" FontSize="14" FontWeight="SemiBold"/>
                                                </StackPanel>
                                            </Grid>
                                        </ScrollViewer>

                                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                                            <Button Content="Cancelar" Style="{StaticResource SecondaryButtonStyle}" Width="100" Height="40" Margin="0,0,12,0" Click="BtnCancelarPacForm_Click"/>
                                            <Button Content="Guardar Paciente" Style="{StaticResource PrimaryButtonStyle}" Width="150" Height="40" Click="BtnGuardarPaciente_Click"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>

                        <!-- PANEL 3: MEDICOS -->
                        <Grid x:Name="PanelMedicos" Visibility="Collapsed">
                            <!-- List View -->
                            <Grid x:Name="GridMedicoList" Visibility="Visible">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Search and Actions -->
                                <Grid Grid.Row="0" Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="Gestión de Médicos" FontSize="22" FontWeight="Bold" Foreground="#1E293B" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1" x:Name="TxtBuscarMedico" Tag="Buscar por nombre, colegiatura o doc..." Style="{StaticResource ModernTextBox}" Height="40" Margin="16,0,8,0" VerticalAlignment="Center"/>
                                    <Button Grid.Column="2" Content="🔍 Buscar" Style="{StaticResource SecondaryButtonStyle}" Width="90" Height="40" Margin="0,0,8,0" Click="BtnBuscarMedico_Click" VerticalAlignment="Center"/>
                                    <Button Grid.Column="3" Content="➕ Registrar Médico" Style="{StaticResource PrimaryButtonStyle}" Height="40" Padding="16,0,16,0" Click="BtnNuevoMedico_Click" VerticalAlignment="Center"/>
                                </Grid>

                                <!-- Table -->
                                <Border Grid.Row="1" Background="#FFFFFF" CornerRadius="12" BorderBrush="#E5E7EB" BorderThickness="1" Padding="12">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <DataGrid Grid.Row="0" x:Name="DgMedicos" Style="{StaticResource ModernDataGrid}">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Colegiatura" Binding="{Binding Colegiatura}" Width="100"/>
                                                <DataGridTextColumn Header="Nombres" Binding="{Binding Nombre}" Width="130"/>
                                                <DataGridTextColumn Header="Apellidos" Binding="{Binding Apellidos}" Width="160"/>
                                                <DataGridTextColumn Header="Horario" Binding="{Binding DisponibilidadHorario}" Width="110"/>
                                                <DataGridTextColumn Header="Correo" Binding="{Binding Correo}" Width="170"/>
                                                <DataGridTextColumn Header="Documento" Binding="{Binding NumeroDoc}" Width="100"/>
                                            </DataGrid.Columns>
                                        </DataGrid>

                                        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                                            <Button Content="✏️ Editar Médico" Style="{StaticResource SecondaryButtonStyle}" Width="140" Height="36" Margin="0,0,8,0" Click="BtnEditarMedico_Click"/>
                                            <Button Content="🗑️ Eliminar Médico" Style="{StaticResource SecondaryButtonStyle}" Foreground="#EF4444" BorderBrush="#FCA5A5" Width="140" Height="36" Click="BtnEliminarMedico_Click"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>

                            <!-- Form View -->
                            <Grid x:Name="GridMedicoForm" Visibility="Collapsed">
                                <Border Background="#FFFFFF" CornerRadius="12" BorderBrush="#E5E7EB" BorderThickness="1" Padding="24">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" x:Name="LblTituloFormMedico" Text="Registrar Médico" FontSize="20" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,16"/>

                                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,16">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,12">
                                                    <TextBlock Text="Nombres *" Style="{StaticResource LabelTextStyle}"/>
                                                    <TextBox x:Name="TxtMedNombre" Tag="Ej. Luis" Style="{StaticResource ModernTextBox}" Height="40"/>
                                                </StackPanel>
                                                <StackPanel Grid.Row="0" Grid.Column="1" Margin="8,0,0,12">
                                                    <TextBlock Text="Apellidos *" Style="{StaticResource LabelTextStyle}"/>
                                                    <TextBox x:Name="TxtMedApellidos" Tag="Ej. Vargas" Style="{StaticResource ModernTextBox}" Height="40"/>
                                                </StackPanel>

                                                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,12">
                                                    <TextBlock Text="Tipo Documento *" Style="{StaticResource LabelTextStyle}"/>
                                                    <ComboBox x:Name="CbMedTipoDoc" Height="40" VerticalContentAlignment="Center">
                                                        <ComboBoxItem Content="DNI" IsSelected="True"/>
                                                        <ComboBoxItem Content="Pasaporte"/>
                                                    </ComboBox>
                                                </StackPanel>
                                                <StackPanel Grid.Row="1" Grid.Column="1" Margin="8,0,0,12">
                                                    <TextBlock Text="Número Documento *" Style="{StaticResource LabelTextStyle}"/>
                                                    <TextBox x:Name="TxtMedNumeroDoc" Tag="Ej. 87654321" Style="{StaticResource ModernTextBox}" Height="40"/>
                                                </StackPanel>

                                                <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,8,12">
                                                    <TextBlock Text="Colegiatura *" Style="{StaticResource LabelTextStyle}"/>
                                                    <TextBox x:Name="TxtMedColegiatura" Tag="Ej. CMP-12345" Style="{StaticResource ModernTextBox}" Height="40"/>
                                                </StackPanel>
                                                <StackPanel Grid.Row="2" Grid.Column="1" Margin="8,0,0,12">
                                                    <TextBlock Text="Disponibilidad Horario *" Style="{StaticResource LabelTextStyle}"/>
                                                    <ComboBox x:Name="CbMedHorario" Height="40" VerticalContentAlignment="Center">
                                                        <ComboBoxItem Content="Mañana (08:00 - 13:00)" IsSelected="True"/>
                                                        <ComboBoxItem Content="Tarde (14:00 - 19:00)"/>
                                                        <ComboBoxItem Content="Completo (08:00 - 17:00)"/>
                                                    </ComboBox>
                                                </StackPanel>

                                                <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,8,12">
                                                    <TextBlock Text="Apodo / Nombre de Usuario *" Style="{StaticResource LabelTextStyle}"/>
                                                    <TextBox x:Name="TxtMedApodo" Tag="Ej. drvargas" Style="{StaticResource ModernTextBox}" Height="40"/>
                                                </StackPanel>
                                                <StackPanel Grid.Row="3" Grid.Column="1" Margin="8,0,0,12">
                                                    <TextBlock Text="Contraseña *" Style="{StaticResource LabelTextStyle}"/>
                                                    <TextBox x:Name="TxtMedContrasena" Tag="Ej. 123" Style="{StaticResource ModernTextBox}" Height="40"/>
                                                </StackPanel>

                                                <StackPanel Grid.Row="4" Grid.Column="0" Margin="0,0,8,12">
                                                    <TextBlock Text="Correo Electrónico *" Style="{StaticResource LabelTextStyle}"/>
                                                    <TextBox x:Name="TxtMedCorreo" Tag="Ej. medico@clinica.com" Style="{StaticResource ModernTextBox}" Height="40"/>
                                                </StackPanel>
                                                <StackPanel Grid.Row="4" Grid.Column="1" Margin="8,0,0,12">
                                                    <TextBlock Text="Dirección *" Style="{StaticResource LabelTextStyle}"/>
                                                    <TextBox x:Name="TxtMedDireccion" Tag="Ej. Av. Aviación 456" Style="{StaticResource ModernTextBox}" Height="40"/>
                                                </StackPanel>

                                                <StackPanel Grid.Row="5" Grid.Column="0" Margin="0,0,8,12">
                                                    <TextBlock Text="Fecha de Nacimiento" Style="{StaticResource LabelTextStyle}"/>
                                                    <DatePicker x:Name="DpMedFechaNacimiento" Height="40" VerticalContentAlignment="Center"/>
                                                </StackPanel>
                                            </Grid>
                                        </ScrollViewer>

                                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                                            <Button Content="Cancelar" Style="{StaticResource SecondaryButtonStyle}" Width="100" Height="40" Margin="0,0,12,0" Click="BtnCancelarMedForm_Click"/>
                                            <Button Content="Guardar Médico" Style="{StaticResource PrimaryButtonStyle}" Width="150" Height="40" Click="BtnGuardarMedico_Click"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>

                        <!-- PANEL 4: CITAS -->
                        <Grid x:Name="PanelCitas" Visibility="Collapsed">
                            <!-- List View -->
                            <Grid x:Name="GridCitaList" Visibility="Visible">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Search and Actions -->
                                <Grid Grid.Row="0" Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="Gestión de Citas" FontSize="22" FontWeight="Bold" Foreground="#1E293B" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1" x:Name="TxtBuscarCita" Tag="Buscar por paciente, médico o estado..." Style="{StaticResource ModernTextBox}" Height="40" Margin="16,0,8,0" VerticalAlignment="Center"/>
                                    <Button Grid.Column="2" Content="🔍 Buscar" Style="{StaticResource SecondaryButtonStyle}" Width="90" Height="40" Margin="0,0,8,0" Click="BtnBuscarCita_Click" VerticalAlignment="Center"/>
                                    <Button Grid.Column="3" Content="➕ Crear Cita" Style="{StaticResource PrimaryButtonStyle}" Height="40" Padding="16,0,16,0" Click="BtnNuevaCita_Click" VerticalAlignment="Center"/>
                                </Grid>

                                <!-- Table -->
                                <Border Grid.Row="1" Background="#FFFFFF" CornerRadius="12" BorderBrush="#E5E7EB" BorderThickness="1" Padding="12">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <DataGrid Grid.Row="0" x:Name="DgCitas" Style="{StaticResource ModernDataGrid}">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Paciente" Binding="{Binding PacienteNombreCompleto}" Width="160"/>
                                                <DataGridTextColumn Header="Médico" Binding="{Binding MedicoNombreCompleto}" Width="160"/>
                                                <DataGridTextColumn Header="Fecha / Hora" Binding="{Binding HoraInicio, StringFormat={}{0:dd/MM/yyyy HH:mm}}" Width="120"/>
                                                <DataGridTextColumn Header="Motivo" Binding="{Binding Motivo}" Width="180"/>
                                                <DataGridTextColumn Header="Estado" Binding="{Binding Estado}" Width="100"/>
                                            </DataGrid.Columns>
                                        </DataGrid>

                                        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                                            <Button Content="✔️ Confirmar" Style="{StaticResource SecondaryButtonStyle}" Foreground="#10B981" BorderBrush="#A7F3D0" Width="110" Height="36" Margin="0,0,8,0" Click="BtnConfirmarCita_Click"/>
                                            <Button Content="🩺 Atender" Style="{StaticResource SecondaryButtonStyle}" Foreground="#0B72E7" BorderBrush="#BFDBFE" Width="100" Height="36" Margin="0,0,8,0" Click="BtnAtenderCita_Click"/>
                                            <Button Content="❌ Cancelar" Style="{StaticResource SecondaryButtonStyle}" Foreground="#EF4444" BorderBrush="#FCA5A5" Width="100" Height="36" Click="BtnCancelarCita_Click"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>

                            <!-- Form View -->
                            <Grid x:Name="GridCitaForm" Visibility="Collapsed">
                                <Border Background="#FFFFFF" CornerRadius="12" BorderBrush="#E5E7EB" BorderThickness="1" Padding="24">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Text="Crear Nueva Cita" FontSize="20" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,16"/>

                                        <StackPanel Grid.Row="1" VerticalAlignment="Top">
                                            <!-- Paciente -->
                                            <StackPanel Margin="0,0,0,16">
                                                <TextBlock Text="Paciente *" Style="{StaticResource LabelTextStyle}"/>
                                                <ComboBox x:Name="CbCitaPaciente" Height="40" DisplayMemberPath="NombreCompleto" SelectedValuePath="ID_Paciente" VerticalContentAlignment="Center"/>
                                            </StackPanel>

                                            <!-- Médico -->
                                            <StackPanel Margin="0,0,0,16">
                                                <TextBlock Text="Médico *" Style="{StaticResource LabelTextStyle}"/>
                                                <ComboBox x:Name="CbCitaMedico" Height="40" DisplayMemberPath="NombreCompleto" SelectedValuePath="ID_Medico" VerticalContentAlignment="Center"/>
                                            </StackPanel>

                                            <!-- Date and time -->
                                            <Grid Margin="0,0,0,16">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                                    <TextBlock Text="Fecha *" Style="{StaticResource LabelTextStyle}"/>
                                                    <DatePicker x:Name="DpCitaFecha" Height="40" VerticalContentAlignment="Center"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                                    <TextBlock Text="Hora (HH:mm) *" Style="{StaticResource LabelTextStyle}"/>
                                                    <TextBox x:Name="TxtCitaHora" Tag="Ej: 09:30" Style="{StaticResource ModernTextBox}" Height="40"/>
                                                </StackPanel>
                                            </Grid>

                                            <!-- Motivo -->
                                            <StackPanel Margin="0,0,0,16">
                                                <TextBlock Text="Motivo de Consulta *" Style="{StaticResource LabelTextStyle}"/>
                                                <TextBox x:Name="TxtCitaMotivo" Tag="Ingrese el motivo detallado de la cita" Style="{StaticResource ModernTextBox}" Height="80" TextWrapping="Wrap" AcceptsReturn="True"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                                            <Button Content="Cancelar" Style="{StaticResource SecondaryButtonStyle}" Width="100" Height="40" Margin="0,0,12,0" Click="BtnCancelarCitaForm_Click"/>
                                            <Button Content="Guardar Cita" Style="{StaticResource PrimaryButtonStyle}" Width="150" Height="40" Click="BtnGuardarCita_Click"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>

                        <!-- PANEL 5: USUARIOS -->
                        <Grid x:Name="PanelUsuarios" Visibility="Collapsed">
                            <!-- List View -->
                            <Grid x:Name="GridUsuarioList" Visibility="Visible">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Search and Actions -->
                                <Grid Grid.Row="0" Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="Administrar Usuarios" FontSize="22" FontWeight="Bold" Foreground="#1E293B" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1" x:Name="TxtBuscarUsuario" Tag="Buscar por nombre, apellidos o correo..." Style="{StaticResource ModernTextBox}" Height="40" Margin="16,0,8,0" VerticalAlignment="Center"/>
                                    <Button Grid.Column="2" Content="🔍 Buscar" Style="{StaticResource SecondaryButtonStyle}" Width="90" Height="40" Margin="0,0,8,0" Click="BtnBuscarUsuario_Click" VerticalAlignment="Center"/>
                                    <Button Grid.Column="3" Content="➕ Registrar Usuario" Style="{StaticResource PrimaryButtonStyle}" Height="40" Padding="16,0,16,0" Click="BtnNuevoUsuario_Click" VerticalAlignment="Center"/>
                                </Grid>

                                <!-- Table -->
                                <Border Grid.Row="1" Background="#FFFFFF" CornerRadius="12" BorderBrush="#E5E7EB" BorderThickness="1" Padding="12">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <DataGrid Grid.Row="0" x:Name="DgUsuarios" Style="{StaticResource ModernDataGrid}">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Nombres" Binding="{Binding Nombre}" Width="130"/>
                                                <DataGridTextColumn Header="Apellidos" Binding="{Binding Apellidos}" Width="160"/>
                                                <DataGridTextColumn Header="Correo" Binding="{Binding Correo}" Width="180"/>
                                                <DataGridTextColumn Header="Rol" Binding="{Binding Rol}" Width="100"/>
                                                <DataGridTextColumn Header="Estado" Binding="{Binding Estado}" Width="100"/>
                                            </DataGrid.Columns>
                                        </DataGrid>

                                        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                                            <Button Content="✏️ Editar Usuario" Style="{StaticResource SecondaryButtonStyle}" Width="140" Height="36" Margin="0,0,8,0" Click="BtnEditarUsuario_Click"/>
                                            <Button Content="🗑️ Desactivar" Style="{StaticResource SecondaryButtonStyle}" Foreground="#EF4444" BorderBrush="#FCA5A5" Width="120" Height="36" Click="BtnDesactivarUsuario_Click"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>

                            <!-- Form View -->
                            <Grid x:Name="GridUsuarioForm" Visibility="Collapsed">
                                <Border Background="#FFFFFF" CornerRadius="12" BorderBrush="#E5E7EB" BorderThickness="1" Padding="24">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" x:Name="LblTituloFormUsuario" Text="Registrar Usuario" FontSize="20" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,16"/>

                                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,16">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,12">
                                                    <TextBlock Text="Nombres *" Style="{StaticResource LabelTextStyle}"/>
                                                    <TextBox x:Name="TxtUsuNombre" Tag="Ej. Ana" Style="{StaticResource ModernTextBox}" Height="40"/>
                                                </StackPanel>
                                                <StackPanel Grid.Row="0" Grid.Column="1" Margin="8,0,0,12">
                                                    <TextBlock Text="Apellidos *" Style="{StaticResource LabelTextStyle}"/>
                                                    <TextBox x:Name="TxtUsuApellidos" Tag="Ej. Gómez" Style="{StaticResource ModernTextBox}" Height="40"/>
                                                </StackPanel>

                                                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,12">
                                                    <TextBlock Text="Correo Electrónico *" Style="{StaticResource LabelTextStyle}"/>
                                                    <TextBox x:Name="TxtUsuCorreo" Tag="Ej. usuario@clinica.com" Style="{StaticResource ModernTextBox}" Height="40"/>
                                                </StackPanel>
                                                <StackPanel Grid.Row="1" Grid.Column="1" Margin="8,0,0,12">
                                                    <TextBlock Text="Rol *" Style="{StaticResource LabelTextStyle}"/>
                                                    <ComboBox x:Name="CbUsuRol" Height="40" VerticalContentAlignment="Center">
                                                        <ComboBoxItem Content="Administrador" IsSelected="True"/>
                                                        <ComboBoxItem Content="Médico"/>
                                                        <ComboBoxItem Content="Recepcionista"/>
                                                    </ComboBox>
                                                </StackPanel>

                                                <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,8,12">
                                                    <TextBlock Text="Contraseña *" Style="{StaticResource LabelTextStyle}"/>
                                                    <TextBox x:Name="TxtUsuContrasena" Tag="Ej. 123456" Style="{StaticResource ModernTextBox}" Height="40"/>
                                                </StackPanel>
                                                <StackPanel Grid.Row="2" Grid.Column="1" Margin="8,0,0,12" VerticalAlignment="Center">
                                                    <TextBlock Text="Estado" Style="{StaticResource LabelTextStyle}"/>
                                                    <ComboBox x:Name="CbUsuEstado" Height="40" VerticalContentAlignment="Center">
                                                        <ComboBoxItem Content="Activo" IsSelected="True"/>
                                                        <ComboBoxItem Content="Inactivo"/>
                                                    </ComboBox>
                                                </StackPanel>
                                            </Grid>
                                        </ScrollViewer>

                                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                                            <Button Content="Cancelar" Style="{StaticResource SecondaryButtonStyle}" Width="100" Height="40" Margin="0,0,12,0" Click="BtnCancelarUsuForm_Click"/>
                                            <Button Content="Guardar Usuario" Style="{StaticResource PrimaryButtonStyle}" Width="150" Height="40" Click="BtnGuardarUsuario_Click"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
