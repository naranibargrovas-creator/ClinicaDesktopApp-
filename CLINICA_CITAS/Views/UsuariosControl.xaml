<UserControl x:Class="CLINICA_CITAS.Views.UsuariosControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:helpers="clr-namespace:CLINICA_CITAS.Helpers"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             Focusable="False"
             IsEnabled="True">
    <UserControl.Resources>
        <helpers:VisibilityToBooleanConverter x:Key="VisibilityToBooleanConverter"/>
    </UserControl.Resources>
    <Grid Focusable="False">
        <!-- List View -->
        <Grid x:Name="GridUsuarioList" Visibility="Visible" IsHitTestVisible="{Binding Visibility, RelativeSource={RelativeSource Self}, Converter={StaticResource VisibilityToBooleanConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Search and Actions -->
            <Grid Grid.Row="0" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Administrar Usuarios" FontSize="22" FontWeight="Bold" Foreground="#1E293B" VerticalAlignment="Center"/>
                <!--<TextBox Grid.Column="1" x:Name="TxtBuscarUsuario" Tag="Buscar por nombre, apellidos o correo..." Style="{StaticResource ModernTextBox}" Height="40" Margin="16,0,8,0" VerticalAlignment="Center"/>-->
                <TextBox Grid.Column="1"
                         x:Name="TxtBuscarUsuario" 
                         Tag="Buscar por nombre, apellidos o correo..." 
                         Height="40"
                         Background="#FFFFFF"
                         Foreground="#1E293B"
                         BorderBrush="#0B72E7"
                         BorderThickness="2"
                         Padding="10,2"
                         FontSize="15"
                         VerticalContentAlignment="Center"
                         CaretBrush="#0B72E7"/>
                <Button Grid.Column="2" Content="🔍 Buscar" Style="{StaticResource SecondaryButtonStyle}" Width="90" Height="40" Margin="0,0,8,0" Click="BtnBuscarUsuario_Click" VerticalAlignment="Center"/>
                <Button Grid.Column="3" Content="➕ Registrar Usuario" Style="{StaticResource PrimaryButtonStyle}" Height="40" Padding="16,0,16,0" Click="BtnNuevoUsuario_Click" VerticalAlignment="Center"/>
            </Grid>

            <!-- Table -->
            <Border Grid.Row="1" Background="#FFFFFF" CornerRadius="12" BorderBrush="#E5E7EB" BorderThickness="1" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DataGrid Grid.Row="0" x:Name="DgUsuarios" Style="{StaticResource ModernDataGrid}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Nombres" Binding="{Binding Nombre}" Width="130"/>
                            <DataGridTextColumn Header="Apellidos" Binding="{Binding Apellidos}" Width="160"/>
                            <DataGridTextColumn Header="Correo" Binding="{Binding Correo}" Width="180"/>
                            <DataGridTextColumn Header="Rol" Binding="{Binding Rol}" Width="100"/>
                            <DataGridTextColumn Header="Estado" Binding="{Binding Estado}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                        <Button Content="✏️ Editar Usuario" Style="{StaticResource SecondaryButtonStyle}" Width="140" Height="36" Margin="0,0,8,0" Click="BtnEditarUsuario_Click"/>
                        <Button Content="🗑️ Desactivar" Style="{StaticResource SecondaryButtonStyle}" Foreground="#EF4444" BorderBrush="#FCA5A5" Width="120" Height="36" Click="BtnDesactivarUsuario_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Form View -->
        <Grid x:Name="GridUsuarioForm" Visibility="Collapsed" IsHitTestVisible="{Binding Visibility, RelativeSource={RelativeSource Self}, Converter={StaticResource VisibilityToBooleanConverter}}">
            <Border Background="#FFFFFF" CornerRadius="12" BorderBrush="#E5E7EB" BorderThickness="1" Padding="24">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" x:Name="LblTituloFormUsuario" Text="Registrar Usuario" FontSize="20" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,16"/>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,12">
                                <TextBlock Text="Nombres *" Style="{StaticResource LabelTextStyle}"/>
                                <!--<TextBox x:Name="TxtUsuNombre" Tag="Ej. Ana" Style="{StaticResource ModernTextBox}" Height="40"/>-->
                                <TextBox 
                                          x:Name="TxtUsuNombre" 
                                          Tag="Ej. Ana" 
                                          Height="40"
                                          Background="#FFFFFF"
                                          Foreground="#1E293B"
                                          BorderBrush="#0B72E7"
                                          BorderThickness="2"
                                          Padding="10,2"
                                          FontSize="15"
                                          VerticalContentAlignment="Center"
                                          CaretBrush="#0B72E7"
                                          MaxLength="20"/>
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="8,0,0,12">
                                <TextBlock Text="Apellidos *" Style="{StaticResource LabelTextStyle}"/>
                                <!--<TextBox x:Name="TxtUsuApellidos" Tag="Ej. Gómez" Style="{StaticResource ModernTextBox}" Height="40"/>-->
                                <TextBox x:Name="TxtUsuApellidos" 
                                          Tag="Ej. Gómez" 
                                          Height="40"
                                          Background="#FFFFFF"
                                          Foreground="#1E293B"
                                          BorderBrush="#0B72E7"
                                          BorderThickness="2"
                                          Padding="10,2"
                                          FontSize="15"
                                          VerticalContentAlignment="Center"
                                          CaretBrush="#0B72E7"
                                           MaxLength="50"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,12">
                                <TextBlock Text="Correo Electrónico *" Style="{StaticResource LabelTextStyle}"/>
                                <!--<TextBox x:Name="TxtUsuCorreo" Tag="Ej. usuario@clinica.com" Style="{StaticResource ModernTextBox}" Height="40"/>-->
                                <TextBox x:Name="TxtUsuCorreo" 
                                          Tag="Ej. usuario@clinica.com" 
                                          Height="40"
                                          Background="#FFFFFF"
                                          Foreground="#1E293B"
                                          BorderBrush="#0B72E7"
                                          BorderThickness="2"
                                          Padding="10,2"
                                          FontSize="15"
                                          VerticalContentAlignment="Center"
                                          CaretBrush="#0B72E7"
                                          MaxLength="50"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="8,0,0,12">
                                <TextBlock Text="Rol *" Style="{StaticResource LabelTextStyle}"/>
                                <ComboBox x:Name="CbUsuRol" Height="40" VerticalContentAlignment="Center">
                                    <ComboBoxItem Content="Administrador" IsSelected="True"/>
                                    <ComboBoxItem Content="Médico"/>
                                    <ComboBoxItem Content="Recepcionista"/>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,8,12">
                                <TextBlock Text="Contraseña *" Style="{StaticResource LabelTextStyle}"/>
                                <!--<TextBox x:Name="TxtUsuContrasena" Tag="Ej. 123456" Style="{StaticResource ModernTextBox}" Height="40"/>-->
                                <TextBox x:Name="TxtUsuContrasena" 
                                        Tag="Ej. 123456" 
                                        Height="40"
                                        Background="#FFFFFF"
                                        Foreground="#1E293B"
                                        BorderBrush="#0B72E7"
                                        BorderThickness="2"
                                        Padding="10,2"
                                        FontSize="15"
                                        VerticalContentAlignment="Center"
                                        CaretBrush="#0B72E7"
                                        MaxLength="20"/>
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="1" Margin="8,0,0,12" VerticalAlignment="Center">
                                <TextBlock Text="Estado" Style="{StaticResource LabelTextStyle}"/>
                                <ComboBox x:Name="CbUsuEstado" Height="40" VerticalContentAlignment="Center">
                                    <ComboBoxItem Content="Activo" IsSelected="True"/>
                                    <ComboBoxItem Content="Inactivo"/>
                                </ComboBox>
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancelar" Style="{StaticResource SecondaryButtonStyle}" Width="100" Height="40" Margin="0,0,12,0" Click="BtnCancelarUsuForm_Click"/>
                        <Button Content="Guardar Usuario" Style="{StaticResource PrimaryButtonStyle}" Width="150" Height="40" Click="BtnGuardarUsuario_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>