<Window x:Class="CLINICA_CITAS.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CLINICA_CITAS"
        mc:Ignorable="d"
        Title="Dashboard - Clínica Citas" 
        Height="500" 
        Width="800"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize">

    <Grid>
        <!-- Outer Shadow / Margin Area -->
        <Border Background="#F3F4F6"
                CornerRadius="16"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                Margin="10">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" 
                                  Direction="-90" 
                                  ShadowDepth="3" 
                                  Opacity="0.15" 
                                  Color="#000000"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <!-- Drag Titlebar -->
                    <RowDefinition Height="40"/>
                    <!-- Dashboard Content -->
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Titlebar -->
                <Border Grid.Row="0" 
                        Background="Transparent" 
                        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid>
                        <!-- App Icon / Title -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                            <TextBlock Text="⚕️" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Clínica Citas - Panel de Control" 
                                       FontFamily="Segoe UI" 
                                       FontWeight="SemiBold" 
                                       Foreground="#4B5563" 
                                       FontSize="12" 
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Window Controls -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,12,0">
                            <Button Content="—" 
                                    Width="30" 
                                    Height="24" 
                                    Background="Transparent" 
                                    BorderThickness="0" 
                                    Foreground="#6B7280" 
                                    FontWeight="Bold"
                                    Cursor="Hand"
                                    Click="BtnMinimize_Click">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="4">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="border" Property="Background" Value="#E5E7EB"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                            
                            <Button Content="✕" 
                                    Width="30" 
                                    Height="24" 
                                    Background="Transparent" 
                                    BorderThickness="0" 
                                    Foreground="#6B7280" 
                                    FontWeight="Bold"
                                    Cursor="Hand"
                                    Click="BtnClose_Click"
                                    Margin="4,0,0,0">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="4">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="border" Property="Background" Value="#EF4444"/>
                                                            <Setter Property="Foreground" Value="White"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Dashboard Body -->
                <Grid Grid.Row="1" Margin="24,8,24,24">
                    <Grid.ColumnDefinitions>
                        <!-- Sidebar -->
                        <ColumnDefinition Width="200"/>
                        <!-- Main Panel -->
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Sidebar Card -->
                    <Border Grid.Column="0" 
                            Background="#FFFFFF" 
                            CornerRadius="12" 
                            BorderBrush="#E5E7EB" 
                            BorderThickness="1"
                            Margin="0,0,16,0">
                        <Grid Margin="16">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Profile Greeting -->
                            <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,16,0,0">
                                <Border Width="60" Height="60" CornerRadius="30" Background="#0B72E7" HorizontalAlignment="Center" Margin="0,0,0,12">
                                    <TextBlock x:Name="TxtInitial" Text="C" Foreground="White" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock x:Name="TxtUserName" Text="Carlos Ramírez" FontSize="16" FontWeight="SemiBold" Foreground="#1E293B" TextAlignment="Center" TextWrapping="Wrap"/>
                                <Border Background="#E0F2FE" CornerRadius="12" Padding="8,4,8,4" Margin="0,6,0,0" HorizontalAlignment="Center">
                                    <TextBlock x:Name="TxtUserRol" Text="Administrador" FontSize="11" FontWeight="Medium" Foreground="#0369A1"/>
                                </Border>
                            </StackPanel>

                            <!-- Navigation List Mock -->
                            <StackPanel Grid.Row="1" Margin="0,24,0,0" VerticalAlignment="Top">
                                <TextBlock Text="Menú del Sistema" FontSize="11" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,8"/>
                                <Border Background="#F1F5F9" CornerRadius="6" Padding="8" Margin="0,0,0,4">
                                    <TextBlock Text="🏠 Inicio" FontSize="13" FontWeight="SemiBold" Foreground="#0B72E7"/>
                                </Border>
                                <StackPanel Margin="8,8,0,0">
                                    <TextBlock Text="📅 Citas" FontSize="13" Foreground="#475569" Cursor="Hand" Margin="0,4,0,4"/>
                                    <TextBlock Text="👤 Pacientes" FontSize="13" Foreground="#475569" Cursor="Hand" Margin="0,4,0,4"/>
                                    <TextBlock Text="📦 Almacén (Insumos)" FontSize="13" Foreground="#475569" Cursor="Hand" Margin="0,4,0,4"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Logout Button -->
                            <Button Grid.Row="2" 
                                    Content="Cerrar Sesión" 
                                    Background="Transparent" 
                                    BorderThickness="0" 
                                    Foreground="#EF4444" 
                                    FontWeight="SemiBold"
                                    Cursor="Hand"
                                    Click="BtnLogout_Click"
                                    Margin="0,0,0,8"/>
                        </Grid>
                    </Border>

                    <!-- Main Welcome Card -->
                    <Border Grid.Column="1" 
                            Background="#FFFFFF" 
                            CornerRadius="12" 
                            BorderBrush="#E5E7EB" 
                            BorderThickness="1">
                        <Grid Margin="32">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="🎉" FontSize="64" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                                <TextBlock Text="¡Inicio de Sesión Exitoso!" 
                                           FontSize="28" 
                                           FontWeight="Bold" 
                                           Foreground="#1E293B" 
                                           HorizontalAlignment="Center" 
                                           Margin="0,0,0,12"/>
                                <TextBlock x:Name="TxtWelcomeMsg" 
                                           Text="Hola Carlos, bienvenido de vuelta. Has iniciado sesión correctamente en el sistema de gestión de citas." 
                                           FontSize="15" 
                                           Foreground="#64748B" 
                                           TextAlignment="Center" 
                                           TextWrapping="Wrap" 
                                           MaxWidth="450" 
                                           LineHeight="22"/>
                                
                                <!-- Decorative Info Card -->
                                <Border Background="#F8FAFC" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1" Padding="16" Margin="0,24,0,0" MaxWidth="400">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="ℹ️" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Top"/>
                                        <StackPanel>
                                            <TextBlock Text="Prueba de Base de Datos" FontSize="13" FontWeight="SemiBold" Foreground="#334155"/>
                                            <TextBlock Text="La conexión con SQL Server está activa. Su fecha de último acceso y estado de sesión han sido registrados en la tabla Usuario." 
                                                       FontSize="12" 
                                                       Foreground="#64748B" 
                                                       TextWrapping="Wrap" 
                                                       Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
