<UserControl x:Class="CLINICA_CITAS.Views.HistorialClinicoControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:helpers="clr-namespace:CLINICA_CITAS.Helpers"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             Focusable="False"
             IsEnabled="True">
    <UserControl.Resources>
        <helpers:VisibilityToBooleanConverter x:Key="VisibilityToBooleanConverter"/>
    </UserControl.Resources>
    <Grid Focusable="False">
        <!-- List View -->
        <Grid x:Name="GridHistorialList" Visibility="Visible" IsHitTestVisible="{Binding Visibility, RelativeSource={RelativeSource Self}, Converter={StaticResource VisibilityToBooleanConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Search and Actions -->
            <Grid Grid.Row="0" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Gestión de Historial Clínico" FontSize="22" FontWeight="Bold" Foreground="#1E293B" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1"
                    x:Name="TxtBuscarHistorial" 
                     Tag="Buscar por paciente, observaciones..." 
                     Height="40"
                     Background="#FFFFFF"
                     Foreground="#1E293B"
                     BorderBrush="#0B72E7"
                     BorderThickness="2"
                     Padding="10,2"
                     FontSize="15"
                     VerticalContentAlignment="Center"
                     CaretBrush="#0B72E7"/>
                <Button Grid.Column="2" Content="🔍 Buscar" Style="{StaticResource SecondaryButtonStyle}" Width="90" Height="40" Margin="0,0,8,0" Click="BtnBuscarHistorial_Click" VerticalAlignment="Center"/>
                <Button Grid.Column="3" Content="➕ Nuevo Historial" Style="{StaticResource PrimaryButtonStyle}" Height="40" Padding="16,0,16,0" Click="BtnNuevoHistorial_Click" VerticalAlignment="Center"/>
            </Grid>

            <!-- Table -->
            <Border Grid.Row="1" Background="#FFFFFF" CornerRadius="12" BorderBrush="#E5E7EB" BorderThickness="1" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DataGrid Grid.Row="0" x:Name="DgHistorial" Style="{StaticResource ModernDataGrid}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Paciente" Binding="{Binding PacienteNombreCompleto}" Width="180"/>
                            <DataGridTextColumn Header="Médico" Binding="{Binding MedicoNombreCompleto}" Width="150"/>
                            <DataGridTextColumn Header="Fecha" Binding="{Binding FechaCreacionHistorial, StringFormat={}{0:dd/MM/yyyy}}" Width="100"/>
                            <DataGridTextColumn Header="Estado" Binding="{Binding Estado}" Width="100"/>
                            <DataGridTextColumn Header="Tipo Sangre" Binding="{Binding TipoSangre}" Width="100"/>
                            <DataGridTextColumn Header="Presión" Binding="{Binding PresionArterial}" Width="100"/>
                            <DataGridTextColumn Header="Observaciones" Binding="{Binding Observaciones}" Width="200"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                        <Button Content="📝 Editar" Style="{StaticResource SecondaryButtonStyle}" Foreground="#0B72E7" BorderBrush="#BFDBFE" Width="100" Height="36" Margin="0,0,8,0" Click="BtnEditarHistorial_Click"/>
                        <Button Content="🗑️ Eliminar" Style="{StaticResource SecondaryButtonStyle}" Foreground="#EF4444" BorderBrush="#FCA5A5" Width="100" Height="36" Click="BtnEliminarHistorial_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Form View -->
        <Grid x:Name="GridHistorialForm" Visibility="Collapsed" IsHitTestVisible="{Binding Visibility, RelativeSource={RelativeSource Self}, Converter={StaticResource VisibilityToBooleanConverter}}">
            <Border Background="#FFFFFF" CornerRadius="12" BorderBrush="#E5E7EB" BorderThickness="1" Padding="24">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" x:Name="LblTituloFormHistorial" Text="Nuevo Historial Clínico" FontSize="20" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,16"/>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Paciente -->
                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,12">
                                <TextBlock Text="Paciente *" Style="{StaticResource LabelTextStyle}"/>
                                <ComboBox x:Name="CbHistorialPaciente" Height="40" DisplayMemberPath="NombreCompleto" SelectedValuePath="ID_Paciente" VerticalContentAlignment="Center" SelectionChanged="CbHistorialPaciente_SelectionChanged"/>
                            </StackPanel>

                            <!-- Cita -->
                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="8,0,0,12">
                                <TextBlock Text="Cita *" Style="{StaticResource LabelTextStyle}"/>
                                <ComboBox x:Name="CbHistorialCita" Height="40" DisplayMemberPath="Motivo" SelectedValuePath="ID_Cita" VerticalContentAlignment="Center"/>
                            </StackPanel>

                            <!-- Estado -->
                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,12">
                                <TextBlock Text="Estado *" Style="{StaticResource LabelTextStyle}"/>
                                <ComboBox x:Name="CbHistorialEstado" Height="40" VerticalContentAlignment="Center">
                                    <ComboBoxItem Content="Activo" IsSelected="True"/>
                                    <ComboBoxItem Content="Inactivo"/>
                                    <ComboBoxItem Content="En tratamiento"/>
                                    <ComboBoxItem Content="Recuperado"/>
                                </ComboBox>
                            </StackPanel>

                            <!-- Tipo Sangre -->
                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="8,0,0,12">
                                <TextBlock Text="Tipo Sangre *" Style="{StaticResource LabelTextStyle}"/>
                                <ComboBox x:Name="CbHistorialTipoSangre" Height="40" VerticalContentAlignment="Center">
                                    <ComboBoxItem Content="O+" IsSelected="True"/>
                                    <ComboBoxItem Content="O-"/>
                                    <ComboBoxItem Content="A+"/>
                                    <ComboBoxItem Content="A-"/>
                                    <ComboBoxItem Content="B+"/>
                                    <ComboBoxItem Content="B-"/>
                                    <ComboBoxItem Content="AB+"/>
                                    <ComboBoxItem Content="AB-"/>
                                </ComboBox>
                            </StackPanel>

                            <!-- Peso -->
                            <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,8,12">
                                <TextBlock Text="Peso (kg)" Style="{StaticResource LabelTextStyle}"/>
                                <TextBox x:Name="TxtHistorialPeso" 
                                          Tag="Ej. 70.5" 
                                          Height="40"
                                          Background="#FFFFFF"
                                          Foreground="#1E293B"
                                          BorderBrush="#0B72E7"
                                          BorderThickness="2"
                                          Padding="10,2"
                                          FontSize="15"
                                          VerticalContentAlignment="Center"
                                          CaretBrush="#0B72E7"/>
                            </StackPanel>

                            <!-- Altura -->
                            <StackPanel Grid.Row="2" Grid.Column="1" Margin="8,0,0,12">
                                <TextBlock Text="Altura (m)" Style="{StaticResource LabelTextStyle}"/>
                                <TextBox x:Name="TxtHistorialAltura" 
                                          Tag="Ej. 1.75" 
                                          Height="40"
                                          Background="#FFFFFF"
                                          Foreground="#1E293B"
                                          BorderBrush="#0B72E7"
                                          BorderThickness="2"
                                          Padding="10,2"
                                          FontSize="15"
                                          VerticalContentAlignment="Center"
                                          CaretBrush="#0B72E7"/>
                            </StackPanel>

                            <!-- Presión Arterial -->
                            <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,8,12">
                                <TextBlock Text="Presión Arterial *" Style="{StaticResource LabelTextStyle}"/>
                                <TextBox x:Name="TxtHistorialPresion" 
                                          Tag="Ej. 120/80" 
                                          Height="40"
                                          Background="#FFFFFF"
                                          Foreground="#1E293B"
                                          BorderBrush="#0B72E7"
                                          BorderThickness="2"
                                          Padding="10,2"
                                          FontSize="15"
                                          VerticalContentAlignment="Center"
                                          CaretBrush="#0B72E7"/>
                            </StackPanel>

                            <!-- Antecedentes -->
                            <StackPanel Grid.Row="3" Grid.Column="1" Margin="8,0,0,12">
                                <TextBlock Text="Antecedentes *" Style="{StaticResource LabelTextStyle}"/>
                                <TextBox x:Name="TxtHistorialAntecedentes" 
                                          Tag="Ej. Diabetes, Hipertensión" 
                                          Height="40"
                                          Background="#FFFFFF"
                                          Foreground="#1E293B"
                                          BorderBrush="#0B72E7"
                                          BorderThickness="2"
                                          Padding="10,2"
                                          FontSize="15"
                                          VerticalContentAlignment="Center"
                                          CaretBrush="#0B72E7"/>
                            </StackPanel>

                            <!-- Observaciones -->
                            <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,12">
                                <TextBlock Text="Observaciones *" Style="{StaticResource LabelTextStyle}"/>
                                <TextBox x:Name="TxtHistorialObservaciones" 
                                          Tag="Observaciones del historial clínico" 
                                          Height="80"
                                          TextWrapping="Wrap"
                                          AcceptsReturn="True"
                                          VerticalScrollBarVisibility="Auto"
                                          Background="#FFFFFF"
                                          Foreground="#1E293B"
                                          BorderBrush="#0B72E7"
                                          BorderThickness="2"
                                          Padding="10,8"
                                          FontSize="15"
                                          VerticalContentAlignment="Top"
                                          CaretBrush="#0B72E7"/>
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancelar" Style="{StaticResource SecondaryButtonStyle}" Width="100" Height="40" Margin="0,0,12,0" Click="BtnCancelarHistorialForm_Click"/>
                        <Button Content="Guardar Historial" Style="{StaticResource PrimaryButtonStyle}" Width="150" Height="40" Click="BtnGuardarHistorial_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
